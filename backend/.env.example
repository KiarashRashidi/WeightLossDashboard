# Copy this file to .env and fill in your values
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-jwt-secret-too
DATABASE_URL=sqlite:///smartweigh.db

# GapGPT (OpenAI-compatible)
GAPGPT_API_KEY=your-gapgpt-api-key-here

# Bale Messenger Bot
BALE_BOT_TOKEN=your-bale-bot-token-here
# Full URL that Bale will POST updates to, e.g. https://yourdomain.com/api/bale/webhook
BALE_WEBHOOK_URL=https://yourdomain.com/api/bale/webhook

# How many days of inactivity before doctor is notified (default 21 = 3 weeks)
SCHEDULER_INACTIVE_DAYS=21

# Default doctor credentials (used only on first run to seed the DB)
ADMIN_USERNAME=doctor
ADMIN_PASSWORD=changeme123
